<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvDialogZoomLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Text Size: 100%"
        android:textColor="@color/ignite_orange"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.slider.Slider
        android:id="@+id/zoomSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="50"
        android:valueTo="280"
        android:stepSize="10"
        android:value="100"
        app:thumbColor="@color/ignite_orange"
        app:trackColorActive="@color/ignite_orange"
        app:trackColorInactive="#33000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical">
        
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/reading_mode_icon"
            app:tint="@color/ignite_orange" />
            
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Immersive Reader Mode"
            android:textColor="#333333"
            android:textSize="16sp" />
            
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchReaderMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

</LinearLayout>
