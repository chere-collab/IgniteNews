<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/app_background">

    <!-- 🏁 Premium Header Background -->
    <View
        android:id="@+id/settingsHeaderBg"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/toolbar_rounded"
        android:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="Profile Settings"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 👤 Dashboard Master Card -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settingsToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <!-- 👤 Profile Head Section -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:civ_border_width="4dp"
                    app:civ_border_color="@color/card_background"
                    android:elevation="6dp" />
                
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnChangePhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:src="@android:drawable/ic_menu_edit"
                    app:fabSize="mini"
                    app:backgroundTint="@color/ignite_orange"
                    app:tint="@android:color/white"
                    app:elevation="8dp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="user@example.com"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 📜 Main Settings Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="READING PREFERENCES"
                        android:textColor="@color/ignite_orange"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- Category Item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Default News Category"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <Spinner
                            android:id="@+id/spinnerDefaultCategory"
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Language Item -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Language Selection"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />
                        <Spinner
                            android:id="@+id/spinnerDefaultLanguage"
                            android:layout_width="140dp"
                            android:layout_height="wrap_content"
                            android:gravity="end" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="24dp"
                        android:background="#1A000000" />

                    <!-- Dark Mode Item -->
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDarkMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Dark Interface"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 📊 Stats Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JOURNEY STATS"
                        android:textColor="@color/ignite_orange"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvReadStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Loading your news history..."
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                    <Button
                        android:id="@+id/btnExportBookmarks"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Export My Reading List"
                        android:textColor="@color/ignite_orange"
                        android:textAllCaps="false" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 📜 Legal & Security -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LEGAL AND SECURITY"
                        android:textColor="@color/ignite_orange"
                        android:letterSpacing="0.1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrivacyPolicy"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Privacy Policy &amp; Terms"
                        android:textColor="@color/text_primary"
                        android:gravity="start"
                        android:textAllCaps="false"
                        app:icon="@android:drawable/ic_menu_info_details"
                        app:iconTint="@color/text_secondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteAccount"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Permanently Delete Account"
                        android:textColor="#D32F2F"
                        android:gravity="start"
                        android:textAllCaps="false"
                        app:icon="@android:drawable/ic_menu_delete"
                        app:iconTint="#D32F2F" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Version 1.0.0 (Elite Edition)"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:textStyle="italic" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Sign Out"
                android:textColor="#D32F2F"
                app:strokeColor="#D32F2F"
                app:cornerRadius="28dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
